# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- Service ---
APP_NAME="EmergenSee Face Recognition API"
APP_VERSION="0.1.0"
ENVIRONMENT=development
DEBUG=true

# --- Server ---
HOST=0.0.0.0
PORT=8000
WORKERS=1
LOG_LEVEL=DEBUG

# --- AI Model Configuration (uncomment in Phase 3) ---
# MODEL_BACKEND=deepface
# FACE_DETECTION_MODEL=retinaface
# FACE_RECOGNITION_MODEL=ArcFace
# MODEL_CACHE_DIR=/app/.model_cache
# INFERENCE_TIMEOUT_SECONDS=30.0

# --- External Services (uncomment when wired up) ---
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/emergensee
# REDIS_URL=redis://localhost:6379/0
